{
  "manifest_version": 3,
  "name": "Nuvoread",
  "description": "Reads page text aloud from the selected word using a local MLX Audio TTS server.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/nuvoread-16.png",
    "32": "icons/nuvoread-32.png",
    "48": "icons/nuvoread-48.png",
    "128": "icons/nuvoread-128.png"
  },
  "action": {
    "default_title": "Nuvoread Settings",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/nuvoread-16.png",
      "32": "icons/nuvoread-32.png",
      "48": "icons/nuvoread-48.png",
      "128": "icons/nuvoread-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
